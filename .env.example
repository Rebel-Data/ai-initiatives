# Copy to .env.local and fill in.

# Prisma / Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/ai_initiatives"

# Shared Rebel SSO (rgmp.net/api/auth/verify)
RGMP_AUTH_URL="https://rgmp.net"
INTERNAL_API_KEY=""

# Local dev only: bypass SSO
# SKIP_AUTH="true"

# Shown in footer
NEXT_PUBLIC_COMMIT_HASH="dev"

# Microsoft Teams "Post adaptive card when a webhook request is received" workflow URL.
# When set, every initiative create/update posts a card to the channel that workflow
# targets. Leave empty to disable notifications (e.g. local dev).
TEAMS_WEBHOOK_URL=""
